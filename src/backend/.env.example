# ========================================
# StockMind AI — 환경변수 템플릿
# 이 파일을 복사하여 .env 로 저장 후 실제 값을 입력하세요
# ========================================

# 서버 설정
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# CORS 허용 도메인 (쉼표 구분)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenDART API (공시 정보)
# 발급: https://opendart.fss.or.kr/
DART_API_KEY=your_dart_api_key_here

# Alpha Vantage API (보조 주가 데이터)
# 발급: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Redis (캐싱 — 없으면 in-memory 폴백)
REDIS_URL=redis://localhost:6379/0

# 데이터베이스 (Phase 2)
# DATABASE_URL=postgresql://user:password@localhost:5432/stockmind

# 캐시 TTL 설정 (초)
CACHE_TTL_STOCK_INFO=300        # 주식 기본 정보: 5분
CACHE_TTL_ANALYSIS=3600         # AI 분석: 1시간
CACHE_TTL_NEWS=600              # 뉴스/공시: 10분
CACHE_TTL_SIGNALS=1800          # 숨겨진 인사이트: 30분
