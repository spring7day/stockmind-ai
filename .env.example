# ============================================================
# StockMind AI — 환경 변수 예제
# 이 파일을 .env로 복사한 후 실제 값을 입력하세요.
# cp .env.example .env
# ============================================================

# ============================================================
# API Keys
# ============================================================

# Anthropic Claude API 키 (https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenDART 공시 API 키 (https://opendart.fss.or.kr)
DART_API_KEY=your_dart_api_key_here

# Alpha Vantage 주가 데이터 API 키 (https://www.alphavantage.co)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# ============================================================
# Database
# ============================================================

# PostgreSQL 연결 URL (Docker 서비스명 사용)
DATABASE_URL=postgresql://stockmind:stockmind_password@db:5432/stockmind

# Redis 연결 URL (Docker 서비스명 사용)
REDIS_URL=redis://redis:6379/0

# ============================================================
# PostgreSQL 설정 (docker-compose에서 직접 사용)
# ============================================================

POSTGRES_DB=stockmind
POSTGRES_USER=stockmind
POSTGRES_PASSWORD=stockmind_password

# ============================================================
# Backend 서버 설정
# ============================================================

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# JWT / 세션 시크릿 키 (프로덕션에서는 반드시 변경)
SECRET_KEY=your_secret_key_here_change_in_production

# CORS 허용 오리진 (쉼표로 구분)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================================
# Frontend 설정
# ============================================================

# 백엔드 API URL (브라우저에서 접근 가능한 주소)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Google AdSense 설정 (광고 수익화)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT_ID=XXXXXXXXXX

# 기능 플래그
NEXT_PUBLIC_ENABLE_ADS=false
NEXT_PUBLIC_ENABLE_MOCK_DATA=false
